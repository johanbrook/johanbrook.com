---
title: Writings
menu:
  visible: true
  order: 5
  top: true
---

{% set posts = search.pages("type=post", "date=desc") %}
{% set firstEverPost = posts | last %}
{% set latestPost = posts | first %}

<main class="Page h-feed">
    <header>
        <h1 class="visually-hidden p-name">{{ title }}</h1>
    
        <p class="subhead">
            {{posts | length }} posts, from <time title="{{ firstEverPost.date | date('Detailed', firstEverPost.timezone) }}" datetime="{{ firstEverPost.date | date('Machine', firstEverPost.timezone) }}">{{ firstEverPost.date | date('MonthYear', firstEverPost.timezone) }}</time> to <time title="{{ latestPost.date | date('Detailed', latestPost.timezone) }}" datetime="{{ latestPost.date | date('Machine', latestPost.timezone) }}">{{ latestPost.date | date('MonthYear', latestPost.timezone) }}</time>.
        </p>
    </header>

    <ol role="list">
        {% for post in posts %}
        <li class="PostItem h-entry" id="{{ post.url | url(true) }}">
            <a class="u-url" href="{{ post.url | url }}" title="About {{ post | readingTime }} reading time">{{ post.title }}</a>

            <div>
                {% if post.draft %}<span class="Badge mr1">Draft</span>{% endif %}
                <time class="font-sans dt-published" datetime="{{ post.date | date('Machine', post.timezone) }}" pubdate>{{ post.date | date('Date', post.timezone) }}</time>
            </div>
        </li>
        {% endfor %}
    </ol>
</main>
